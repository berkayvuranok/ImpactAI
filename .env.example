# Application
APP_NAME=code-impact-predictor
APP_ENV=development
DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# Security
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
DATABASE_URL=postgresql+asyncpg://cip:cip_secret@postgres:5432/code_impact
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION_COMMITS=commits
QDRANT_COLLECTION_ISSUES=issues
QDRANT_COLLECTION_DOCS=docs

# LLM (explanation only — not prediction)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=2048
LLM_BACKEND=mock

# ML Models
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_BACKEND=sentence_transformer
GNN_MODEL_PATH=/app/models/gnn/latest.pt
RISK_MODEL_PATH=/app/models/risk/latest.pt
INFERENCE_DEVICE=cpu
XAI_ENABLED=true
XAI_USE_SHAP_LIBRARY=false

# Evaluation
EVALUATION_STORAGE_PATH=/data/evaluations
EVALUATION_BENCHMARK_PATH=data/benchmarks

AUTH_ENABLED=false
GITHUB_WEBHOOK_SECRET=
GITLAB_WEBHOOK_SECRET=

# Git Storage
GIT_STORAGE_PATH=/data/repos
GRAPH_STORAGE_PATH=/data/graphs
MAX_REPO_SIZE_MB=500

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Monitoring
PROMETHEUS_ENABLED=true
LOG_LEVEL=INFO
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
